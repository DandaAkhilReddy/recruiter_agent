# Azure OpenAI
AOAI_ENDPOINT=https://YOUR-AOAI.openai.azure.com/
AOAI_API_KEY=replace-me
AOAI_API_VERSION=2024-08-01-preview
AOAI_GPT4O_DEPLOYMENT=gpt-4o
AOAI_GPT4O_MINI_DEPLOYMENT=gpt-4o-mini
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AOAI_EMBEDDING_DIMENSIONS=1536

# Database (local docker = pgvector/pgvector:pg16)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recruiter

# App
ENV=local
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:3000

# Pipeline tuning (defaults shown)
CANDIDATE_POOL_SIZE=500
RERANK_TOP_K=50
RERANK_BATCH_SIZE=10
OUTREACH_TOP_K=20
MAX_CONVERSATION_TURNS=4

# Frontend (Next.js — must be prefixed NEXT_PUBLIC_ to be exposed at build)
NEXT_PUBLIC_API_URL=http://localhost:8000
